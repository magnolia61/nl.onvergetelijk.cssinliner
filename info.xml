<?xml version="1.0"?>
<extension key="nl.onvergetelijk.cssinliner" type="module">
  <file>cssinliner</file>
  <name>Onvergetelijk CSS Inliner</name>
  <description>Converteert CSS style blocks naar inline styles in CiviCRM mailings voor optimale weergave in e-mailclients (PHP 8.4 proof).</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Richard van Oosterhout</author>
    <email>webteam@onvergetelijk.nl</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://www.onvergetelijk.nl</url>
    <url desc="Documentation">https://www.onvergetelijk.nl</url>
    <url desc="Support">https://www.onvergetelijk.nl</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-03-29</releaseDate>
  <version>1.0.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.11</ver>
  </compatibility>
  <comments>Moderne vervanger voor de verouderde fuzion cssinline, geoptimaliseerd voor PHP 8.4.</comments>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/Cssinliner</namespace>
    <format>25.01.1</format>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
  </mixins>
</extension>